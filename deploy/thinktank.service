[Unit]
Description=RSS International News to DingTalk Push Service
After=network.target

[Service]
Type=simple
User=lucas
WorkingDirectory=/home/lucas/AI/News/rss
EnvironmentFile=/home/lucas/AI/News/rss/.env
ExecStart=/home/lucas/AI/News/rss/.venv/bin/python main.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
